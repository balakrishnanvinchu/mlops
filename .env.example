# Environment variables for MLOps project

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=models/artifacts/model.pt
DEVICE=cuda

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cats-vs-dogs-classification

# Data Configuration
DATA_PATH=data/processed
RAW_DATA_PATH=data/raw

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Docker Registry (for CI/CD)
REGISTRY=ghcr.io
IMAGE_NAME=cats-dogs-classifier
